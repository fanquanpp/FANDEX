{
  "$ref": "#/definitions/docs",
  "definitions": {
    "docs": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "module": {
          "type": "string"
        },
        "category": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "difficulty": {
          "type": "string",
          "enum": [
            "beginner",
            "intermediate",
            "advanced"
          ]
        },
        "order": {
          "type": "number",
          "default": 0
        },
        "created": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "updated": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "author": {
          "type": "string",
          "default": "fanquanpp"
        },
        "description": {
          "type": "string"
        },
        "readingTime": {
          "type": "number"
        },
        "related": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "prerequisites": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "quiz": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string",
                    "const": "fill"
                  },
                  "question": {
                    "type": "string"
                  },
                  "answer": {
                    "type": "string"
                  },
                  "hint": {
                    "type": "string"
                  }
                },
                "required": [
                  "type",
                  "question",
                  "answer"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string",
                    "const": "choice"
                  },
                  "question": {
                    "type": "string"
                  },
                  "options": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "answer": {
                    "type": "number"
                  },
                  "explanation": {
                    "type": "string"
                  }
                },
                "required": [
                  "type",
                  "question",
                  "options",
                  "answer"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string",
                    "const": "fix"
                  },
                  "question": {
                    "type": "string"
                  },
                  "code": {
                    "type": "string"
                  },
                  "answer": {
                    "type": "string"
                  },
                  "explanation": {
                    "type": "string"
                  }
                },
                "required": [
                  "type",
                  "question",
                  "answer"
                ],
                "additionalProperties": false
              }
            ]
          },
          "default": []
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "module"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}