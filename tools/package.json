{
  "name": "@fandex/tools",
  "version": "1.0.0",
  "description": "FANDEX 工具链：manifest 生成、ID 分配、Ed25519 签名与验签",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "generate-manifest": "tsx src/generate-manifest.ts",
    "allocate-id": "tsx src/allocate-id.ts",
    "sign-manifest": "tsx src/sign-manifest.ts",
    "verify-manifest": "tsx src/verify-manifest.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "node --test --import tsx src/**/*.test.ts"
  },
  "dependencies": {
    "@noble/ed25519": "^2.1.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0"
  }
}
