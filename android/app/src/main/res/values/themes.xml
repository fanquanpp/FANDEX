<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        FANDEX 应用主题
        - parent: 使用系统 Material 主题（NoActionBar）
        - windowBackground: 指定启动背景色，由 values/values-night 资源限定符
          根据系统暗/浅色模式自动切换（v3.6.0：支持双主题）
        - 注意: 项目为 Compose-only 应用，UI 主题由 MaterialTheme(colorScheme=...) 控制，
          此 XML 主题仅用于 Activity 启动阶段（Compose 内容渲染前）。
          Compose 内容渲染后即由 FANDEXTheme 接管配色，并读取 DataStore 中的用户偏好。
    -->
    <style name="Theme.FANDEX" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/window_background</item>
    </style>
</resources>
