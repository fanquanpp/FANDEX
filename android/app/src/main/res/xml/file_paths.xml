<?xml version="1.0" encoding="utf-8"?>
<!--
    FileProvider 共享路径配置

    仅允许访问应用专属缓存目录下的 downloads 子目录，
    用于存放更新自检功能下载的 APK 文件。
    PackageInstaller 通过 FileProvider 临时读取该路径下的 APK 进行安装。

    路径说明：
    - cache-path：对应 Context.getCacheDir()，应用卸载时自动清理
    - external-cache-path：对应 Context.getExternalCacheDir()，便于用户手动管理
-->
<paths>
    <!-- 内部缓存目录：存放下载的 APK 文件 -->
    <cache-path
        name="downloads"
        path="downloads/" />

    <!-- 外部缓存目录：备用存储路径（大文件场景） -->
    <external-cache-path
        name="external_downloads"
        path="downloads/" />
</paths>
