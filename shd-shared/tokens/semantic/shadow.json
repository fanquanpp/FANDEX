{
  "$description": "FANDEX 语义阴影令牌 — 引用 primitive/shadow.json，ark 家族克制阴影",
  "shadow": {
    "$type": "shadow",
    "control": { "$value": "{shadow.xs}", "$description": "控件阴影（悬停态）" },
