    "card-hover": { "$value": "{shadow.default}", "$description": "卡片悬停阴影" },
    "dropdown": { "$value": "{shadow.md}", "$description": "下拉菜单阴影" },
    "popover": { "$value": "{shadow.lg}", "$description": "气泡卡片阴影" },
    "modal": { "$value": "{shadow.xl}", "$description": "模态框阴影" },
    "notification": { "$value": "{shadow.2xl}", "$description": "通知提醒阴影" },
    "focus-ring": { "$value": "{shadow.inner}", "$description": "焦点内阴影" }
  }
