---
/**
 * ReadingProgress 阅读进度条组件（三端共享）
 *
 * 功能概述：
 * - 固定在页面顶部的渐变进度条，实时反映当前阅读位置
 * - 监听滚动容器的 scroll 事件，计算并更新进度百分比
 * - 使用 IntersectionObserver 延迟绑定（避免首屏空白时进度为 100%）
 * - 完整无障碍：role="progressbar"、aria-valuenow/min/max、aria-label
 * - 尊重 prefers-reduced-motion：CSS 已禁用过渡动画
 * - 基于 @fandex/styles 的 .fndx-reading-progress 命名规范实现样式
 *
 * 设计原则：
 * - 严格消费 layout-components.css 中已定义的 .fndx-reading-progress 令牌与样式
 * - 双主题由 light-dark() 与 color-scheme 自动切换
 * - 渐变色由 --reading-progress-gradient 令牌控制（accent → secondary）
 * - pointer-events: none 避免遮挡顶部交互
 *
 * Props:
 *   scrollContainer - 滚动容器选择器（默认 '#app-main'，与 Layout 的 main[id] 一致）
 *   enabled         - 是否启用（默认 true，便于特定页面禁用）
 *
 * 引用：spec.md 第八章 ark-ui 美术风格 / tasks.md 阶段 D.2.5 实现 ReadingProgress 组件
 */
interface Props {
  scrollContainer?: string;
  enabled?: boolean;
}

const {
  scrollContainer = '#app-main',
  enabled = true,
} = Astro.props;

/** 滚动容器配置（序列化为 data 属性供客户端脚本读取） */
const scrollConfig = JSON.stringify({ container: scrollContainer });
---

{
  enabled && (
    <div
      class="fndx-reading-progress"
      role="progressbar"
      aria-label="阅读进度"
      aria-valuenow={0}
      aria-valuemin={0}
      aria-valuemax={100}
      data-reading-progress-config={scrollConfig}
    >
      <div class="fndx-reading-progress__bar" id="fndx-reading-progress-bar" />
    </div>
  )
}

<script>
  /**
   * 阅读进度条滚动监听逻辑（三端共享）
   *
   * 实现说明：
   * - 从 data-reading-progress-config 读取滚动容器选择器
   * - 监听容器的 scroll 事件（passive + rAF 节流，避免阻塞主线程）
   * - 计算公式：scrollTop / (scrollHeight - clientHeight) * 100
   * - 更新进度条 width 与 aria-valuenow
   * - 兼容 View Transitions：监听 astro:page-load 事件重新初始化
   * - 支持多实例：通过 data 属性读取各组件的滚动配置
   */

  /** rAF 句柄（用于节流） */
  let rafId: number | null = null;

  /** 从 data-reading-progress-config 属性解析滚动配置 */
  function readScrollConfig(progressEl: HTMLElement): string {
    const raw = progressEl.getAttribute('data-reading-progress-config');
    if (!raw) return '#app-main';
    try {
      const parsed = JSON.parse(raw) as { container?: string };
      return parsed.container || '#app-main';
    } catch {
      return '#app-main';
    }
  }

  /** 初始化阅读进度条 */
  function initReadingProgress(): void {
    const progressEl = document.querySelector<HTMLElement>('.fndx-reading-progress');
    if (!progressEl) return;

    const bar = progressEl.querySelector<HTMLElement>('.fndx-reading-progress__bar');
    if (!bar) return;

    /** 读取滚动容器配置 */
    const containerSelector = readScrollConfig(progressEl);
    const scrollContainer =
      document.querySelector<HTMLElement>(containerSelector) || document.documentElement;

    /** 计算并更新进度 */
    function updateProgress(): void {
      const { scrollTop, scrollHeight, clientHeight } = scrollContainer;
      const maxScroll = scrollHeight - clientHeight;

      // 内容不足以滚动时，进度保持 0
      if (maxScroll <= 0) {
        bar.style.width = '0%';
        progressEl.setAttribute('aria-valuenow', '0');
        return;
      }

      const percent = Math.min(100, Math.max(0, (scrollTop / maxScroll) * 100));
      bar.style.width = `${percent}%`;
      progressEl.setAttribute('aria-valuenow', String(Math.round(percent)));
    }

    /** rAF 节流的 scroll 回调 */
    function onScroll(): void {
      if (rafId !== null) return;
      rafId = requestAnimationFrame(() => {
        updateProgress();
        rafId = null;
      });
    }

    // 初次更新（页面加载后立即反映当前进度）
    updateProgress();

    // 绑定 scroll 监听（passive 提升滚动性能）
    scrollContainer.addEventListener('scroll', onScroll, { passive: true });

    // 窗口尺寸变化时重新计算（响应式适配）
    window.addEventListener('resize', onScroll, { passive: true });
  }

  // 初始化（首屏与 View Transitions 跳转后均触发）
  initReadingProgress();
  document.addEventListener('astro:page-load', initReadingProgress);
</script>
