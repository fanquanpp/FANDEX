---
import Breadcrumb from '@/components/Breadcrumb.astro';
/**
 * roadmap.astro 学习路线图（Phase 8a 重写版，v3.1.0 升级为 G2 力导向图）
 *
 * 功能概述：
 * - 从 shd-shared/metadata/roadmap/career-paths.json 实时读取职业学习路径
 * - 通过 KnowledgeGraph 岛屿（client:visible）渲染全模块依赖力导向图，
 *   基于 AntV G2 v5 chart.forceGraph()，支持缩放、平移、下载、全屏、节点点击跳转
 * - 按 8 大分类（tools/frontend/backend/database/cs/math/cloud/ai）展示所有模块卡片
 * - 完全移除 Vue、@fandex/shared 与 AIRoadmap.astro 组件依赖
 * - 模块数据全部来自 @/lib/modules（基于 metadata/modules.json）
 * - Tailwind v4 工具类实现布局
 * - Tauri 兼容：使用 withBase() 处理模块链接
 *
 * 数据流：
 * 1. 构建期：从 MODULES + MODULE_CATEGORIES 生成静态 HTML 与力导向图数据 { nodes, links }
 * 2. 运行时：KnowledgeGraph 岛屿在进入视口时水合，用户点击按钮后动态加载 G2 渲染
 * 3. 模块点击跳转到 /modules/{moduleId}/ 详情页
 *
 * 偏差报备（仓库整理后数据源迁移）：
 * - 原：4 条推荐路径硬编码在组件内（RECOMMENDED_PATHS）
 * - 新：从 shd-shared/metadata/roadmap/career-paths.json 实时读取全部职业路径
 * - 迁移依据：消除 app-desktop 硬编码数据，统一从 shd-shared/metadata/ 实时读取
 * - v3.0.x 使用 MermaidLazy 渲染 Mermaid graph TD，v3.1.0 改为 AntV G2 力导向图
 *   用户原始要求：「力导向图替换为组件 G2。一切以 ts 和 react 为主。」
 */
import Layout from '@/components/Layout.astro';
import SEO from '@/components/SEO.astro';
import KnowledgeGraph, { type KnowledgeLink, type KnowledgeNode } from '@/islands/KnowledgeGraph';
import { getModule, MODULE_CATEGORIES, MODULES, type Module } from '@/lib/modules';
import { withBase } from '@/lib/url';
// 从共享元数据实时读取职业路径（shd-shared/metadata/roadmap/career-paths.json）
import { getCareerPaths } from '@fandex/utils/metadata';

/** 面包屑层级（首页 > 学习路线图） */
const breadcrumbs = [{ label: '首页', href: '/' }, { label: '学习路线图' }] as const;

/** 推荐学习路径类型 */
interface LearningPath {
  /** 路径唯一 ID */
  id: string;
  /** 路径标题 */
  title: string;
  /** 路径描述 */
  description: string;
  /** 路径主题色 */
  color: string;
  /** 步骤模块 ID 数组（按学习顺序） */
  steps: readonly string[];
}

/**
 * 从 shd-shared/metadata/roadmap/career-paths.json 实时读取职业学习路径
 *
 * 将共享元数据中的 CareerPath 结构（label/color/steps[{id,label}]）
 * 转换为模板所需的 LearningPath 结构（id/title/description/color/steps[string[]]）。
 *
 * - id：使用索引生成稳定标识（用于 Vue/React key）
 * - title：直接使用 careerPath.label
 * - description：由首尾步骤标签拼接（如 "入门指南 → JavaScript"）
 * - color：直接使用 careerPath.color
 * - steps：提取各步骤的模块 ID 数组
 */
const RECOMMENDED_PATHS: readonly LearningPath[] = getCareerPaths().map((path, index) => ({
  id: `career-path-${index}`,
  title: path.label,
  description:
    path.steps.length >= 2
      ? `${path.steps[0].label} → ${path.steps[path.steps.length - 1].label}`
      : path.steps[0]?.label ?? path.label,
  color: path.color,
  steps: path.steps.map((step) => step.id),
}));

/**
 * 构建全模块依赖力导向图数据
 *
 * 实现说明：
 * - 节点 ID 直接使用模块 ID（G2 支持任意字符串 ID，无需字符转义）
 * - 节点 group 取模块所属分类，label 取模块名称
 * - 节点 href 指向模块详情页，点击可跳转
 * - 节点 value 根据前置依赖数量微调：依赖越多节点越大，凸显核心枢纽模块
 * - 边表示 prerequisites 依赖关系（A 依赖 B → B-->A，即先学 B 再学 A）
 * - 仅添加源模块与目标模块均存在的边，避免悬空引用
 *
 * @returns 力导向图数据 { nodes, links }
 */
function buildModuleGraphData(): { nodes: KnowledgeNode[]; links: KnowledgeLink[] } {
  /** 收集所有模块 ID，用于校验依赖是否存在 */
  const moduleIds = new Set(MODULES.map((m) => m.id));

  /** 节点：每个模块一个节点 */
  const nodes: KnowledgeNode[] = MODULES.map((m) => ({
    id: m.id,
    label: m.name,
    group: m.category,
    href: withBase(`/modules/${m.id}/`),
    // 前置依赖越多节点越大（凸显枢纽模块），范围 6-14
    value: Math.min(14, 6 + m.prerequisites.length),
    status: 'unread',
  }));

  /** 边：遍历所有模块的 prerequisites，添加依赖关系 */
  const links: KnowledgeLink[] = [];
  for (const module of MODULES) {
    for (const prereqId of module.prerequisites) {
      if (!moduleIds.has(prereqId)) continue;
      links.push({ source: prereqId, target: module.id });
    }
  }

  return { nodes, links };
}

/** 全模块依赖力导向图数据（构建期生成） */
const moduleGraphData = buildModuleGraphData();

/** 用于校验路径步骤是否存在，过滤掉不存在的模块 */
function resolvePathModules(stepIds: readonly string[]): readonly Module[] {
  return stepIds.map((id) => getModule(id)).filter((m): m is Module => m !== undefined);
}
---

<Layout title="学习路线图 - FANDEX" description={`FANDEX 知识库推荐学习路线，覆盖 ${RECOMMENDED_PATHS.length} 条职业方向，从零基础到工程师`} hasSidebar={false}>
  <SEO
    slot="head"
    title="学习路线图 - FANDEX"
    description={`FANDEX 知识库推荐学习路线，覆盖 ${RECOMMENDED_PATHS.length} 条职业方向，从零基础到工程师。包含模块依赖图与分类导航。`}
    type="website"
    breadcrumbs={breadcrumbs}
  />

  <Breadcrumb items={breadcrumbs} />

  <section class="space-y-10 py-6 md:py-10">
    <!-- 页面标题 -->
    <header class="space-y-2">
      <h1 class="text-3xl font-bold tracking-tight md:text-4xl">学习路线图</h1>
      <p class="max-w-2xl text-sm text-muted-foreground md:text-base">
        FANDEX 知识库推荐学习路线，覆盖 {RECOMMENDED_PATHS.length} 条职业方向。每条路径包含从零基础到工程师的关键模块，配合依赖图理解模块间的前置关系。
      </p>
    </header>

    <!-- 推荐学习路径 -->
    <section class="space-y-4">
      <div class="flex items-center gap-2">
        <h2 class="text-xl font-semibold tracking-tight md:text-2xl">推荐学习路径</h2>
        <span class="rounded-full border border-border bg-muted/40 px-2 py-0.5 text-[11px] text-muted-foreground">
          {RECOMMENDED_PATHS.length} 条
        </span>
      </div>

      <div class="grid gap-3">
        {RECOMMENDED_PATHS.map((path) => {
          const modules = resolvePathModules(path.steps);
          return (
            <article
              class="group relative overflow-hidden rounded-lg border border-border bg-card/50 p-4 transition-colors hover:bg-card md:p-5"
              style={`--path-color:${path.color}`}
            >
              {/* 左侧色条 */}
              <span
                class="absolute inset-y-0 left-0 w-1"
                style={`background:${path.color}`}
                aria-hidden="true"
              />

              <div class="ml-2 space-y-3">
                {/* 路径标题 */}
                <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
                  <h3 class="text-base font-semibold md:text-lg" style={`color:${path.color}`}>
                    {path.title}
                  </h3>
                  <p class="text-xs text-muted-foreground md:text-sm">{path.description}</p>
                </div>

                {/* 路径步骤流 */}
                <ol class="flex flex-wrap items-center gap-2">
                  {modules.map((module, index) => (
                    <li class="flex items-center gap-2">
                      <a
                        href={withBase(`/modules/${module.id}/`)}
                        class="inline-flex items-center gap-1.5 rounded-md border border-border bg-background px-2.5 py-1 text-xs font-medium text-foreground transition-colors hover:border-[var(--path-color)] hover:text-[var(--path-color)]"
                        style={index === 0 ? `border-color:${path.color}40` : undefined}
                      >
                        <span
                          class="flex h-5 w-5 items-center justify-center rounded text-[10px] font-bold"
                          style={`background:${path.color}20;color:${path.color}`}
                          aria-hidden="true"
                        >
                          {module.icon}
                        </span>
                        {module.name}
                      </a>
                      {index < modules.length - 1 && (
                        <span class="text-muted-foreground/60" aria-hidden="true">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="9 18 15 12 9 6" />
                          </svg>
                        </span>
                      )}
                    </li>
                  ))}
                </ol>
              </div>
            </article>
          );
        })}
      </div>
    </section>

    <!-- 模块依赖力导向图（KnowledgeGraph 岛屿，G2 渲染） -->
    <section class="space-y-3">
      <div class="flex items-center gap-2">
        <h2 class="text-xl font-semibold tracking-tight md:text-2xl">模块依赖图</h2>
        <span class="rounded-full border border-border bg-muted/40 px-2 py-0.5 text-[11px] text-muted-foreground">
          {MODULES.length} 个模块
        </span>
      </div>
      <p class="text-sm text-muted-foreground">
        展示所有模块的前置依赖关系，按 8 大分类分组。点击下方"查看交互版"渲染为可缩放、可平移的力导向图，支持节点点击跳转模块详情。
      </p>
      <KnowledgeGraph
        client:visible
        nodes={moduleGraphData.nodes}
        links={moduleGraphData.links}
        id="module-dependency-graph"
        className="w-full"
        height={480}
      />
    </section>

    <!-- 8 大分类模块列表 -->
    <section class="space-y-6">
      <div class="flex items-center gap-2">
        <h2 class="text-xl font-semibold tracking-tight md:text-2xl">分类模块</h2>
        <span class="rounded-full border border-border bg-muted/40 px-2 py-0.5 text-[11px] text-muted-foreground">
          {MODULE_CATEGORIES.length} 大分类
        </span>
      </div>

      <div class="space-y-5">
        {MODULE_CATEGORIES.map((category) => (
          <article class="overflow-hidden rounded-lg border border-border bg-card/30">
            {/* 分类标题栏 */}
            <header
              class="flex items-center gap-2.5 border-b border-border bg-muted/30 px-4 py-2.5"
              style={`border-left:3px solid ${category.color}`}
            >
              <span
                class="flex h-7 w-7 items-center justify-center rounded text-xs font-bold"
                style={`background:${category.color}20;color:${category.color}`}
                aria-hidden="true"
              >
                {category.icon}
              </span>
              <h3 class="text-sm font-semibold md:text-base">{category.name}</h3>
              <span class="ml-auto text-[11px] text-muted-foreground">
                {category.modules.length} 个模块
              </span>
            </header>

            {/* 模块网格 */}
            <ul class="grid gap-px bg-border/40 sm:grid-cols-2 lg:grid-cols-3">
              {category.modules.map((module) => (
                <li>
                  <a
                    href={withBase(`/modules/${module.id}/`)}
                    class="group flex h-full items-start gap-3 bg-card/80 p-3 transition-colors hover:bg-accent"
                  >
                    <span
                      class="mt-0.5 flex h-7 w-7 flex-shrink-0 items-center justify-center rounded text-[11px] font-bold"
                      style={`background:${category.color}20;color:${category.color}`}
                      aria-hidden="true"
                    >
                      {module.icon}
                    </span>
                    <div class="min-w-0 flex-1 space-y-0.5">
                      <div class="flex items-center gap-1.5">
                        <span class="truncate text-sm font-medium text-foreground group-hover:text-[var(--path-color)]">
                          {module.name}
                        </span>
                        {module.prerequisites.length > 0 && (
                          <span
                            class="rounded border border-border bg-muted/40 px-1 py-0 text-[9px] text-muted-foreground"
                            title={`${module.prerequisites.length} 个前置依赖`}
                          >
                            {module.prerequisites.length}
                          </span>
                        )}
                      </div>
                      <p class="line-clamp-2 text-[11px] text-muted-foreground">{module.description}</p>
                    </div>
                  </a>
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </section>
  </section>
</Layout>
