{
  "name": "@fandex/desktop",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "FANDEX Desktop — Expo + React Native + Tauri 2 桌面端（三端共享 L3/L4 层）",
  "scripts": {
    "dev": "astro dev",
    "build": "node ./scripts/build-glossary-index.mjs && node ./scripts/build-module-docs-index.mjs && node ./scripts/build-tag-index.mjs && node ./scripts/generate-knowledge-graph.mjs && astro build && node ./scripts/build-search-index.mjs",
    "preview": "astro preview",
    "expo:start": "expo start",
    "expo:web": "expo start --web",
    "expo:build:web": "expo export --platform web --output-dir dist-web",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "typecheck": "tsc --noEmit",
    "qa": "node ./scripts/qa-check.mjs"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "dependencies": {
    "@antv/g2": "^5.4.8",
