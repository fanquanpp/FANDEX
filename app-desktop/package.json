{
  "name": "@fandex/desktop",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "FANDEX Desktop — Expo + React Native + Tauri 2 桌面端（三端共享 L3/L4 层）",
  "scripts": {
    "dev": "expo start",
    "expo:start": "expo start",
    "expo:web": "expo start --web",
    "expo:build:web": "expo export --platform web --output-dir dist-web",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "typecheck": "tsc --noEmit",
    "qa": "node ./scripts/qa-check.mjs"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "dependencies": {
    "@expo/metro-runtime": "latest",
    "@fandex/shared-assets": "workspace:*",
    "@fandex/utils": "workspace:*",
    "@tauri-apps/api": "catalog:",
    "@tauri-apps/plugin-fs": "catalog:",
    "@tauri-apps/plugin-http": "catalog:",
    "expo": "latest",
    "expo-constants": "latest",
    "expo-linking": "latest",
    "expo-router": "latest",
    "expo-status-bar": "latest",
    "fuse.js": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-native": "latest",
    "react-native-web": "latest",
    "rehype-autolink-headings": "catalog:",
    "rehype-katex": "catalog:",
    "rehype-slug": "catalog:",
    "remark-emoji": "catalog:",
    "remark-gfm": "catalog:",
    "remark-math": "catalog:",
    "unist-util-visit": "catalog:",
    "zod": "catalog:",
    "zustand": "catalog:"
  },
  "devDependencies": {
    "@babel/core": "latest",
    "@tauri-apps/cli": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "katex": "catalog:",
    "mermaid": "latest",
    "sharp": "latest",
    "typescript": "catalog:"
  }
}
