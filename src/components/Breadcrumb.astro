---
const { items } = Astro.props as { items: { label: string; href?: string }[] }
---

<nav class="breadcrumb">
  {items.map((item, i) => {
    const isMobileHidden = items.length > 2 && i > 0 && i < items.length - 1
    return (
      <>
        {i > 0 && <span class="bc-sep">/</span>}
        {isMobileHidden ? (
          <>
            <span class="bc-ellipsis" aria-hidden="true">...</span>
            <span class="bc-sep bc-sep-mobile" aria-hidden="true">/</span>
          </>
        ) : null}
        {item.href ? (
          <a href={item.href} class={`bc-link${isMobileHidden ? ' bc-mobile-hide' : ''}`}>{item.label}</a>
        ) : (
          <span class={`bc-current${isMobileHidden ? ' bc-mobile-hide' : ''}`}>{item.label}</span>
        )}
      </>
    )
  })}
</nav>

<style>
.breadcrumb {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
  padding: var(--spacing-sm) 0;
  margin-bottom: var(--spacing-lg);
  font-size: 0.82em;
  border-bottom: 1px solid var(--color-border-light);
  max-width: var(--content-width);
  margin-left: auto;
  margin-right: auto;
}

.bc-sep {
  color: var(--color-text-tertiary);
  opacity: 0.4;
  font-family: var(--font-display);
}

.bc-ellipsis {
  display: none;
  color: var(--color-text-tertiary);
  font-family: var(--font-display);
}

.bc-sep-mobile {
  display: none;
}

.bc-link {
  color: var(--color-text-secondary);
}

.bc-link:hover {
  color: var(--color-primary);
}

.bc-current {
  color: var(--color-text);
  font-weight: 500;
  font-family: var(--font-display);
}

@media (max-width: 768px) {
  .bc-ellipsis {
    display: inline;
  }

  .bc-sep-mobile {
    display: inline;
  }

  .bc-mobile-hide {
    display: none;
  }
}
</style>
