---
/**
 * Footer 组件 — 统一底部信息区
 * -----------------------------------------------------------------------------
 * 职责：
 *   1. 渲染跨页面统一的页脚内容（生态链接、导航链接、版权信息）
 *   2. 通过 variant 控制显示模式：full（首页完整版）/ compact（信息页精简版）
 *   3. 通过 currentPath 标记当前所在页面的导航链接高亮
 *   4. 消费 @fandex/styles 中 .fndx-footer 命名规范，与 desktop 端样式统一
 *
 * 使用方式：
 *   <Footer variant="full" stats={stats} />           // 首页
 *   <Footer variant="compact" />                       // 精简版
 *
 * 引用：
 *   - shd-shared/styles/layout-components.css  .fndx-footer 系列样式
 *   - spec.md 第八章 ark-ui 美术风格 / tasks.md 阶段 D.2.2
 */
import { SITE } from '@/lib/constants';

interface Props {
  /** 显示模式：full 为首页完整版（含生态链接/统计/技术信息/注意事项），compact 为信息页精简版 */
  variant?: 'full' | 'compact';
  /** 统计数据，仅 full 模式使用 */
  stats?: {
    totalDocs: number;
    totalModules: number;
    totalTags: number;
  };
  /** 当前页面标识，用于高亮对应导航链接 */
  currentPath?: string;
}

const { variant = 'compact', stats, currentPath } = Astro.props;
const base = import.meta.env.BASE_URL;
const currentYear = new Date().getFullYear();

/** 导航链接配置：仓库级文档已迁移至 docs/ 目录，此处仅保留外部链接 */
const navLinks = [
  {
    label: 'GitHub',
    href: 'https://github.com/fanquanpp/FANDEX-web',
    key: 'github',
    external: true,
  },
];

/** 生态联动链接：跨平台入口 */
const ecoLinks = [
  {
    label: 'FANDEX-web · 线上平台',
    href: 'https://github.com/fanquanpp/FANDEX-web',
    current: true,
  },
];

/** 居中布局修饰符：两种模式均使用居中布局 */
const footerClass = 'fndx-footer fndx-footer--centered';
---

<footer class={footerClass} role="contentinfo" aria-label="站点页脚">
  <div class="fndx-footer__container">
    {/* 生态联动链接区（仅 full 模式显示） */}
    {variant === 'full' && (
      <div class="fndx-footer__eco-links">
        {ecoLinks.map((link) => (
          <a
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            class={`fndx-footer__eco-link${link.current ? ' is-current' : ''}`}
          >
            {link.label}
          </a>
        ))}
      </div>
    )}

    {/* 导航链接组 */}
    <nav class="fndx-footer__nav" aria-label="页脚导航">
      {navLinks.map((link, idx) => (
        <>
          {idx > 0 && <span class="fndx-footer__divider" aria-hidden="true">|</span>}
          <a
            href={link.href}
            class={`fndx-footer__nav-link${currentPath === link.key ? ' is-current' : ''}`}
            {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
          >
            {link.label}
          </a>
        </>
      ))}
    </nav>

    {/* 统计数据区（仅 full 模式显示） */}
    {variant === 'full' && stats && (
      <div class="fndx-footer__stats">
        <span>{stats.totalDocs} 篇文档</span>
        <span class="fndx-footer__divider" aria-hidden="true">·</span>
        <span>{stats.totalModules} 个模块</span>
        <span class="fndx-footer__divider" aria-hidden="true">·</span>
        <span>{stats.totalTags} 个标签</span>
      </div>
    )}

    {/* 技术信息（仅 full 模式显示） */}
    {variant === 'full' && (
      <div class="fndx-footer__tech">
        Built with Astro 7 SSG · Progressive Web App
      </div>
    )}

    {/* 注意事项（仅 full 模式显示） */}
    {variant === 'full' && (
      <>
        <p class="fndx-footer__notice">
          内容由人工与 AI 共同编撰，可能存在遗漏或错误，请结合官方资料独立验证
        </p>
        <p class="fndx-footer__notice">
          更新后构建约需 12 分钟，已访问页面需手动刷新方可显示最新版本
        </p>
      </>
    )}

    {/* 底部版权区 */}
    <div class="fndx-footer__bottom">
      <p class="fndx-footer__copyright">
        Copyright (c) 2024-{currentYear} {SITE.author || 'fanquanpp'} · MIT License
      </p>
    </div>
  </div>
</footer>
